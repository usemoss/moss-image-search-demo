# Copy this file to .env and fill in your values.
# All sub-projects (backend-py, setup-js, setup-py, react-app) read from this single file.

MOSS_PROJECT_ID=your_project_id
MOSS_PROJECT_KEY=your_project_key
MOSS_INDEX_NAME=coco-data

# URL of the Python FastAPI backend (used by the React app)
MOSS_PYTHON_API_URL=http://localhost:8000

# Comma-separated allowed CORS origins for the backend
MOSS_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
